{
  "name": "multipass",
  "version": "0.1.0",
  "description": "World Republic voter verification using zkPassport registry",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "author": "World Republic <info@worldrepublic.org>",
  "homepage": "https://www.worldrepublic.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/worldrepublicorg/multipass.git"
  },
  "bugs": {
    "url": "https://github.com/worldrepublicorg/multipass/issues"
  },
  "keywords": [
    "zkpassport",
    "identity",
    "passport",
    "privacy",
    "react-native",
    "mobile",
    "multipass",
    "world-republic"
  ],
  "scripts": {
    "android": "node scripts/run-android.mjs",
    "android:release": "node scripts/build-release-android.mjs",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "registry:fetch-bundled": "node scripts/fetch-bundled-registry-certs.mjs"
  },
  "codegenConfig": {
    "name": "MultipassTurboModulesSpec",
    "type": "modules",
    "jsSrcsDir": "specs",
    "android": {
      "javaPackageName": "org.worldrepublic.multipass.turbomodules"
    }
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@peculiar/asn1-cms": "^2.3.15",
    "@peculiar/asn1-ecc": "^2.3.15",
    "@peculiar/asn1-rsa": "^2.3.15",
    "@peculiar/asn1-schema": "^2.3.15",
    "@peculiar/asn1-x509": "^2.3.15",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "@zkpassport/registry": "0.14.0",
    "@zkpassport/utils": "0.36.1",
    "buffer": "^6.0.3",
    "pako": "^2.1.0",
    "phosphor-react-native": "^3.0.6",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-biometrics": "^3.0.1",
    "react-native-bootsplash": "^7.3.1",
    "react-native-encrypted-storage": "^4.0.3",
    "react-native-fs": "^2.20.0",
    "react-native-gesture-handler": "^3.0.0",
    "react-native-get-random-values": "^1.11.0",
    "react-native-safe-area-context": "^5.6.0",
    "react-native-screens": "^4.25.0",
    "react-native-svg": "^15.15.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.3",
    "@react-native-community/cli-platform-android": "20.1.3",
    "@react-native-community/cli-platform-ios": "20.1.3",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/eslint-config": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@react-native/typescript-config": "0.85.3",
    "@types/jest": "^29.5.14",
    "@types/pako": "^2.0.4",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "babel-jest": "^29.6.3",
    "eslint": "^9.39.0",
    "jest": "^29.6.3",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.11.0"
  },
  "overrides": {
    "eslint-plugin-ft-flow": "3.0.11"
  }
}
